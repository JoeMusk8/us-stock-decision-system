  "source_layers": [
    {
      "layer_id": "official_disclosure",
      "layer_name": "官方披露数据",
      "purpose": "用于验证公司业务、产品、收入分部、管理层表述、风险披露和监管文件。",
      "credibility": "高",
      "requires_human_review": true,
      "risk_note": "官方披露可能滞后，不能把披露存在直接等同于主题受益成立。"
    },
    {
      "layer_id": "market_data",
      "layer_name": "市场行情数据",
      "purpose": "用于市场资金监控、市场环境判断、策略标注状态展示和数据新鲜度检查。",
      "credibility": "中高",
      "requires_human_review": true,
      "risk_note": "不同供应商可能存在口径差异，延迟数据不能冒充实时数据。"
    },
    {
      "layer_id": "macro_data",
      "layer_name": "宏观数据",
      "purpose": "用于核心利率、核心通胀、核心就业、核心GDP和原油等宏观环境监控。",
      "credibility": "高",
      "requires_human_review": true,
      "risk_note": "宏观数据可能滞后或被修正，不能把单一指标解释为交易结论。"
    },
    {
      "layer_id": "news_contracts_government",
      "layer_name": "新闻 / 公告 / 政府合同数据",
      "purpose": "用于捕捉新证据、新风险、政府资金流向、合同、拨款、政策事件和公司公告。",
      "credibility": "中到高",
      "requires_human_review": true,
      "risk_note": "摘要可能遗漏上下文，政府合同和拨款不得被伪造成真实订单或确定收入。"
    },
    {
      "layer_id": "social_kol_clues",
      "layer_name": "社交媒体 / KOL 线索数据",
      "purpose": "用于发现线索、情绪变化、关注方向和可能的新主题。",
      "credibility": "低到中",
      "requires_human_review": true,
      "risk_note": "只能作为线索，不能直接作为事实结论。"
    }
  ],
